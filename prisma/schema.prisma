generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  password      String?  // hashed, null for SSO-only
  image         String?  // profile picture URL
  active        Boolean  @default(true)
  isAdmin       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  entries       Entry[]
  auditLogs     AuditLog[]
  userRoles     UserRole[]
  
  // NextAuth
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  
  userRoles        UserRole[]
  primaryEntries   Entry[]     @relation("PrimaryRole")
  secondaryEntries EntryRole[]
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  @@id([userId, roleId])
}

model Entry {
  id            String   @id @default(cuid())
  userId        String
  activityHours Float
  travelHours   Float    @default(0)
  totalHours    Float    // computed: activityHours + travelHours
  notes         String?  @db.Text
  primaryRoleId String?
  date          DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  primaryRole    Role?       @relation("PrimaryRole", fields: [primaryRoleId], references: [id])
  secondaryRoles EntryRole[]
}

model EntryRole {
  entryId String
  roleId  String
  entry   Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  role    Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  @@id([entryId, roleId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  details   String?  @db.Text
  ipAddress String?
  createdAt DateTime @default(now())
  
  user      User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model AdminSettings {
  id                  String   @id @default("singleton")
  leaderboardSize     Int      @default(10)
  footerText          String   @default("CadetHours3 © 2025")
  allowNameChange     Boolean  @default(true)
  allowAvatarChange   Boolean  @default(true)
  allowPasswordChange Boolean  @default(true)
  updatedAt           DateTime @updatedAt
}
